---
import '../styles/main.scss';
import Telemetry from '../components/Telemetry.astro';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const siteTitle = 'Alexis Creuzot';
const description =
  'Personal website of Alexis Creuzot, iOS developer, co-founder of Monoqle and Happy Hours Coworking';
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{title ? title : siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="facebook-domain-verification" content="6nzeukurhjdvrvv7byiu1khra6wdm7" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=2" />
    <link rel="manifest" href="/images/site.webmanifest?v=2" />

    <link rel="canonical" href={canonical.href} />
  </head>

  <body>
    <slot />
    <Telemetry />
  </body>
</html>
