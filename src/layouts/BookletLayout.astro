---
import '../booklet/styles/booklet.scss';
import type { BookletData } from '../booklet/types';
import SlideRenderer from '../booklet/components/SlideRenderer.astro';

interface Props extends BookletData {}

const { meta, slides } = Astro.props;

const runtimeConfig = {
  storagePrefix: meta.storagePrefix,
  wifi: meta.wifi,
  strings: meta.strings,
  exportLibs: [
    'https://unpkg.com/html-to-image@1.11.13/dist/html-to-image.js',
    'https://unpkg.com/jszip@3.10.1/dist/jszip.min.js',
  ],
};
---

<!DOCTYPE html>
<html lang={meta.lang} data-booklet-theme={meta.theme}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{meta.title}</title>
<link rel="icon" href="assets/icons/favicon.ico" sizes="any">
<link rel="icon" type="image/svg+xml" href="assets/icons/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="assets/icons/favicon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="assets/icons/favicon-16.png">
<link rel="apple-touch-icon" sizes="180x180" href="assets/icons/apple-touch-icon.png">
<link rel="manifest" href="assets/icons/site.webmanifest">
<meta name="theme-color" content={meta.themeColor}>
<meta name="apple-mobile-web-app-title" content={meta.appleMobileWebAppTitle}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Allura&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<div class="toolbar">
  <div class="title">{meta.toolbar.prefix}<b>{meta.toolbar.emphasis}</b><span class="tb-suffix">{meta.toolbar.suffix}</span></div>
  <div class="spacer"></div>
  <div class="seg" id="viewSeg" role="tablist" aria-label="View">
    <button class="seg-btn is-active" id="segRead" type="button" role="tab" aria-selected="true" data-view="read"><i data-lucide="book-open"></i><span>Read</span></button>
    <button class="seg-btn" id="segGrid" type="button" role="tab" aria-selected="false" data-view="grid"><i data-lucide="layout-grid"></i><span>Grid</span></button>
  </div>
  <button class="btn" id="downloadAll"><i data-lucide="download"></i><span>Download all (.zip)</span></button>
</div>

<div class="deck" id="deck">
  {slides.map((slide) => (
    <SlideRenderer slide={slide} mark={meta.mark} wifi={meta.wifi} wifiSvg={meta.wifiSvg} />
  ))}
</div>

<div class="book-thumbs" id="bookThumbs" aria-label="Page thumbnails"></div>

<div class="book-bar" id="bookBar" role="toolbar" aria-label="Book controls">
  <button id="bookFirst" type="button" aria-label="First page" title="First page"><i data-lucide="chevrons-left"></i></button>
  <button id="bookPrev" type="button" aria-label="Previous page" title="Previous page"><i data-lucide="chevron-left"></i></button>
  <span class="book-count" id="bookCount">1 / 1</span>
  <button id="bookNext" type="button" aria-label="Next page" title="Next page"><i data-lucide="chevron-right"></i></button>
  <button id="bookLast" type="button" aria-label="Last page" title="Last page"><i data-lucide="chevrons-right"></i></button>
  <span class="book-sep"></span>
  <button id="bookThumbsToggle" type="button" aria-label="Show pages" title="Pages"><i data-lucide="layout-grid"></i></button>
</div>

<div class="m-progress" aria-hidden="true"></div>
<div class="m-counter" aria-hidden="true"></div>
<div class="m-scrollcue" aria-hidden="true"></div>
<div class="m-hint" aria-hidden="true"><span class="m-hint-trail"></span><span class="m-hint-finger"></span></div>
<div class="wifi-toast" id="wifiToast" role="status" aria-live="polite"></div>

<script is:inline defer src="https://unpkg.com/lucide@0.469.0/dist/umd/lucide.min.js"></script>
<script is:inline define:vars={{ runtimeConfig }}>
  window.BOOKLET = runtimeConfig;
</script>
<script>
  import { initBooklet } from '../booklet/booklet.ts';

  function boot() {
    if (window.lucide) window.lucide.createIcons();
    initBooklet();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
</script>
</body>
</html>
