---
import { homes } from '../data/homes';
---

<section id="homes">
  <div class="container">
    <h2 class="section__title">Homes I Host</h2>
    <p class="section__subtitle">Places to stay, hosted with care</p>
    <div class="homes__list">
      {
        homes.map((item) => (
          <div class="homes__item">
            <div class="homes__item-cover">
              <img class="homes__item-image" src={item.image} alt={item.name} loading="lazy" />
              <a href={item.url} class="homes__item-cta" target="_blank" rel="noopener">
                <span>View on Airbnb</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              </a>
              <div class="homes__item-overlay">
                <div class="homes__item-overlay-text">
                  <h3 class="homes__item-name">{item.name}</h3>
                  <span class="homes__item-location">{item.location}</span>
                </div>
              </div>
            </div>
            <div class="homes__item-body">
              {item.description && <p class="homes__item-description">{item.description}</p>}
              {item.photos && item.photos.length > 0 && (
                <div class="homes__item-gallery">
                  {item.photos.map((photo) => (
                    <div class="homes__item-thumb">
                      <img src={photo} alt="" loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
