---
import { works } from '../data/works';
import { websites } from '../data/websites';

interface Slide {
  kind: 'iOS' | 'Web';
  name: string;
  tagline: string;
  description: string;
  color: string;
  href: string;
  cta: string;
  icon?: string;
  screenshot?: string;
  image?: string;
}

const excluded = ['dailycig', 'pilot', 'follow', 'cycle', 'cyqle'];

const apps: Slide[] = works
  .filter((p) => !excluded.includes(p.id) && p.appid)
  .map((p) => ({
    kind: 'iOS',
    name: p.name,
    tagline: p.tagline,
    description: p.description,
    color: p.color,
    href: `https://itunes.apple.com/app/${p.appid}`,
    cta: 'App Store',
    icon: p.icon,
    screenshot: p.screenshot,
  }));

const webs: Slide[] = websites.map((w) => ({
  kind: 'Web',
  name: w.name,
  tagline: w.tagline,
  description: w.description,
  color: w.color,
  href: w.discontinued && w.archive_url ? w.archive_url : `https://${w.url}`,
  cta: w.url,
  icon: w.icon ?? `https://www.google.com/s2/favicons?domain=${w.url}&sz=128`,
  image: w.image,
}));

// Weave a website slide in after every two apps
const slides: Slide[] = [];
for (let a = 0, w = 0; a < apps.length || w < webs.length; ) {
  for (let k = 0; k < 2 && a < apps.length; k++) slides.push(apps[a++]);
  if (w < webs.length) slides.push(webs[w++]);
}

const total = String(slides.length).padStart(2, '0');
---

<section id="work" class="block work">
  <div class="container">
    <header class="section-head reveal">
      <div class="section-head__meta"><span class="eyebrow">01 — Work</span></div>
      <h2 class="section-head__title">Selected <em>work</em></h2>
      <p class="section-head__sub">
        A decade of apps and websites — some my own ideas, some built for clients.
      </p>
    </header>

    <div class="showcase reveal" data-showcase>
      <div class="showcase__stage" data-stage>
        {
          slides.map((slide, i) => (
            <article
              class:list={['showcase__slide', { 'is-active': i === 0 }]}
              style={`--c: #${slide.color}`}
              data-slide
            >
              <div class="showcase__content">
                <div class="showcase__top">
                  <span class:list={['showcase__icon', { 'showcase__icon--round': slide.kind === 'Web' }]}>
                    <img src={slide.icon} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
                  </span>
                  <span class="showcase__kind">{slide.kind}</span>
                </div>

                <h3 class="showcase__name">{slide.name}</h3>
                <p class="showcase__tagline">{slide.tagline}</p>
                <p class="showcase__desc">{slide.description}</p>

                <a href={slide.href} class="showcase__link" target="_blank" rel="noopener">
                  {slide.cta}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7" />
                    <polyline points="7 7 17 7 17 17" />
                  </svg>
                </a>
              </div>

              {slide.kind === 'iOS' && slide.screenshot && (
                <div class="showcase__media showcase__media--phone">
                  <img src={slide.screenshot} alt={`${slide.name} screenshot`} loading="lazy" />
                </div>
              )}

              {slide.kind === 'Web' && slide.image && (
                <div class="showcase__media showcase__media--browser">
                  <div class="showcase__window">
                    <span class="showcase__browser-bar">
                      <i />
                      <i />
                      <i />
                    </span>
                    <img src={slide.image} alt={`${slide.name} preview`} loading="lazy" />
                  </div>
                </div>
              )}
            </article>
          ))
        }
      </div>

      <div class="showcase__bar">
        <div class="showcase__nav">
          <button type="button" class="showcase__btn" data-prev aria-label="Previous project">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
          </button>
          <button type="button" class="showcase__btn" data-next aria-label="Next project">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </div>
        <span class="showcase__counter"><span data-counter>01</span> / {total}</span>
      </div>

      <div class="showcase__index" aria-label="All projects">
        {
          slides.map((slide, i) => (
            <>
              <button
                type="button"
                class:list={['showcase__word', { 'is-active': i === 0 }]}
                style={`--c: #${slide.color}`}
                data-goto={i}
              >
                {slide.name}
              </button>
              {i < slides.length - 1 && <span class="showcase__sep" aria-hidden="true">✺</span>}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>
