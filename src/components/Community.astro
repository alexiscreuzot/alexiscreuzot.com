---
import { community } from '../data/community';
---

<section id="community" class="block block--cream block--slim community">
  <div class="container">
    <div class="community__head reveal">
      <span class="eyebrow">02 — Footnotes</span>
      <p class="community__lede">Open-source libraries, a talk, some writing — shared along the way.</p>
    </div>

    <div class="community__cloud reveal">
      {
        community.map((item) => (
          <a href={item.link} class="gift-pill" target="_blank" rel="noopener" aria-label={`${item.type}: ${item.title}`}>
            <span class="gift-pill__emoji">{item.emoji}</span>
            {item.title}
          </a>
        ))
      }
    </div>
  </div>
</section>
