{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "jekyll",
  "buildCommand": "JEKYLL_ENV=production bundle exec jekyll build",
  "outputDirectory": "_site",
  "routes": [
    {
      "src": "/horizonte33/(.*)",
      "has": [{ "type": "host", "value": "horizonte33.alexiscreuzot.com" }],
      "dest": "/horizonte33/$1"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "horizonte33.alexiscreuzot.com" }],
      "dest": "/horizonte33/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "horizonte33.alexiscreuzot.com" }],
      "dest": "/horizonte33/$1"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "zen-in-rennes.alexiscreuzot.com" }],
      "dest": "/zen-in-rennes/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "zen-in-rennes.alexiscreuzot.com" }],
      "dest": "/zen-in-rennes/$1"
    },
    { "handle": "filesystem" }
  ]
}
